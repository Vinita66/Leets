class Solution {
    public int findPoisonedDuration(int[] timeSeries, int duration) {
        int n = timeSeries.length;
        int total = 0;
        if(n == 0){
            return 0;
        }
        for(int i = 1; i < n; i++){
            int interval = timeSeries[i]-timeSeries[i-1];
            total += Math.min(interval, duration);
        }
        total += duration;
        return total;
    }
}
