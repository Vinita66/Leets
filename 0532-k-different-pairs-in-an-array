class Solution {
    public int findPairs(int[] nums, int k) {
        HashSet<Integer> seen = new HashSet<>();
        HashSet<Integer> pairs = new HashSet<>();
        for(int num : nums){
            if(seen.contains(num-k)){
                pairs.add(num-k);
            }
            if(seen.contains(num+k)){
                pairs.add(num);
            }
            seen.add(num);
        }
        return pairs.size();
    }
}
