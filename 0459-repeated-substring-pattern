class Solution {
    public boolean repeatedSubstringPattern(String s) {
        int len = s.length();
        for(int i = 1; i <= len/2; i++){
            if(len % i == 0){
                int count = len/i;
                String pattern = s.substring(0,i);
                StringBuilder sb = new StringBuilder();
                for(int j = 0; j < count; j++){
                    sb.append(pattern);
                }
                if(sb.toString().equals(s)){
                    return true;
                }
            }
        }
        return false;
    }
}
