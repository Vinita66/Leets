class Solution {
    public int[] limitOccurrences(int[] nums, int k) {
        int index =  0;
        for(int num:nums){
            if(index < k || nums[index-k] != num){
                nums[index] = num;
                index++;
            }
        }
        int[] result = new int[index];
        for(int i = 0; i < index; i++){
            result[i] = nums[i];
        }
        return result;
        
    }
}
