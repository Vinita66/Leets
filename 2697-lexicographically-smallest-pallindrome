class Solution {
    public String makeSmallestPalindrome(String s) {
        StringBuilder sb = new StringBuilder(s);
        
        int left = 0;
        int right = s.length()-1;
        while(left < right){
            if(s.charAt(left) < s.charAt(right)){
                sb.setCharAt(right, sb.charAt(left));
            }else{
                sb.setCharAt(left, sb.charAt(right));
                
            }
            left++;
            right--;
        }return sb.toString();
    }
}
