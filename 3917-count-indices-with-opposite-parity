class Solution {
    public int[] countOppositeParity(int[] nums) {
        int n = nums.length;
        int[] ans = new int[n];
        int evenCount = 0;
        int oddCount = 0;
        for(int i = n-1; i>=0; i--){
            if(nums[i] % 2 == 0){
                ans[i] = oddCount;
                evenCount++;
            }else{
                ans[i] = evenCount;
                oddCount++;
            }
        }
        return ans;
    }
}
